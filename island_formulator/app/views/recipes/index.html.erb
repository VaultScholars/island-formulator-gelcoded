<div class="max-w-6xl mx-auto p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-purple-700">📖 My Recipes 📖</h1>
    <%= link_to "✨ New Recipe", new_recipe_path, class: "bg-purple-400 text-white px-6 py-2 rounded-lg font-bold hover:bg-purple-500 transition-colors shadow-sm" %>
  </div>

  <% if @recipes.empty? %>
    <div class="text-center py-12 bg-purple-50 rounded-lg shadow border-2 border-dashed border-purple-200">
      <p class="text-purple-400 mb-4 text-lg">No recipes yet... time to create something magical! ✨</p>
      <%= link_to "Create Your First Recipe", new_recipe_path, class: "text-purple-500 font-semibold hover:text-purple-700 underline decoration-purple-300" %>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @recipes.each do |recipe| %>
        <div class="bg-white rounded-lg shadow hover:shadow-lg transition-all hover:-translate-y-1 border border-purple-100">
          <% if recipe.photo.attached? %>
            <%= image_tag recipe.photo, class: "w-full h-48 object-cover rounded-t-lg" %>
          <% else %>
            <div class="w-full h-48 bg-gradient-to-br from-purple-100 to-pink-100 rounded-t-lg flex items-center justify-center text-purple-400 text-4xl">
              🧪
            </div>
          <% end %>
          
          <div class="p-4">
            <h2 class="text-xl font-bold mb-2"><%= link_to recipe.title, recipe, class: "text-purple-700 hover:text-purple-500" %></h2>
            <span class="inline-block bg-purple-100 text-purple-600 text-xs px-2 py-1 rounded-full font-semibold uppercase tracking-wide">
              ✦ <%= recipe.product_type %> ✦
            </span>
            <p class="text-purple-400 text-sm mt-2">✨ <%= pluralize(recipe.ingredients.count, 'ingredient') %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>