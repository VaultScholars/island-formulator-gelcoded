<% content_for :title, "Editing inventory item" %>

<div class="max-w-4xl mx-auto px-4">
  <!-- Decorative header -->
  <div class="mb-8 text-center">
    <div class="flex justify-center items-center gap-2 mb-3">
      <span class="text-4xl animate-bounce" style="animation-duration: 2s;">✏️</span>
      <span class="text-4xl">📦</span>
      <span class="text-4xl animate-bounce" style="animation-duration: 2s; animation-delay: 0.3s;">✨</span>
    </div>
    
    <h1 class="font-bold text-4xl text-purple-700 mb-2">
      Edit Inventory Item
    </h1>
    
    <p class="text-purple-400 mb-3">Update your item details below 🌸</p>
    
    <!-- Decorative gradient line -->
    <div class="w-32 h-1 bg-gradient-to-r from-purple-300 via-pink-300 to-purple-300 mx-auto rounded-full"></div>
  </div>

  <!-- Form container with corner decorations -->
  <div class="bg-white rounded-2xl shadow-xl p-1 border-2 border-purple-100 relative">
    <!-- Decorative corner sparkles -->
    <span class="absolute -top-2 -left-2 text-2xl">✨</span>
    <span class="absolute -top-2 -right-2 text-2xl">✨</span>
    <span class="absolute -bottom-2 -left-2 text-2xl">✨</span>
    <span class="absolute -bottom-2 -right-2 text-2xl">✨</span>
    
    <%= render "form", inventory_item: @inventory_item %>
  </div>

  <!-- Action buttons - Super cute! -->
  <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-end">
    <%= link_to @inventory_item,
        class: "group flex items-center justify-center gap-2 px-5 py-3 bg-purple-50 text-purple-600 rounded-xl hover:bg-purple-100 transition-all duration-200 border-2 border-purple-200 shadow-sm hover:shadow-md" do %>
      <span>👁️</span>
      <span class="font-medium">Show this item</span>
      <span class="group-hover:translate-x-1 transition-transform">→</span>
    <% end %>

    <%= link_to inventory_items_path,
        class: "group flex items-center justify-center gap-2 px-5 py-3 bg-white text-purple-400 rounded-xl hover:text-purple-600 hover:bg-purple-50 transition-all duration-200 border-2 border-purple-200 shadow-sm hover:shadow-md" do %>
      <span class="group-hover:-translate-x-1 transition-transform">←</span>
      <span>🌸</span>
      <span class="font-medium">Back to inventory</span>
    <% end %>
  </div>

  <!-- Cute reminder message -->
  <div class="mt-8 text-center">
    <p class="text-purple-300 text-sm">
      <span class="inline-block animate-pulse">💜</span>
      Keep your inventory up to date!
      <span class="inline-block animate-pulse">💜</span>
    </p>
    <div class="mt-2 text-purple-200 text-xs">
      ✦ ✦ ✦ ✦ ✦
    </div>
  </div>
</div>