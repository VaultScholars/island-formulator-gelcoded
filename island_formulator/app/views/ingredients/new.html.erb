<% content_for :title, "New ingredient" %>

<div class="max-w-4xl mx-auto px-4">
  <!-- Decorative header with sparkles -->
  <div class="mb-8 text-center">
    <div class="flex justify-center items-center gap-2 mb-3">
      <span class="text-4xl animate-bounce" style="animation-duration: 2s;">✨</span>
      <span class="text-4xl">🥥</span>
      <span class="text-4xl animate-bounce" style="animation-duration: 2s; animation-delay: 0.3s;">✨</span>
    </div>
    
    <h1 class="font-bold text-4xl text-purple-700 mb-2">
      Create New Ingredient
    </h1>
    
    <p class="text-purple-400 mb-3">Add something magical to your collection! 🌸</p>
    
    <!-- Decorative gradient line -->
    <div class="w-32 h-1 bg-gradient-to-r from-purple-300 via-pink-300 to-purple-300 mx-auto rounded-full"></div>
  </div>

  <!-- Form container with extra cuteness -->
  <div class="bg-white rounded-2xl shadow-lg p-1 border-2 border-purple-100 relative">
    <!-- Decorative corner sparkles -->
    <span class="absolute -top-2 -left-2 text-2xl">✨</span>
    <span class="absolute -top-2 -right-2 text-2xl">✨</span>
    <span class="absolute -bottom-2 -left-2 text-2xl">✨</span>
    <span class="absolute -bottom-2 -right-2 text-2xl">✨</span>
    
    <%= render "form", ingredient: @ingredient %>
  </div>

  <!-- Back button with cute styling -->
  <div class="mt-8 flex justify-center sm:justify-start">
    <%= link_to ingredients_path,
        class: "group flex items-center gap-3 px-6 py-3 bg-purple-50 text-purple-600 rounded-xl hover:bg-purple-100 transition-all duration-200 border-2 border-purple-200 shadow-sm hover:shadow-md" do %>
      <span class="group-hover:-translate-x-1 transition-transform">←</span>
      <span>🌸</span>
      <span class="font-medium">Back to ingredients</span>
      <span class="text-purple-300">✦</span>
    <% end %>
  </div>

  <!-- Cute motivational message -->
  <div class="mt-8 text-center text-purple-300 text-sm">
    <p>Every ingredient tells a story... what will yours be? 💜</p>
    <div class="mt-2">✧ ✧ ✧</div>
  </div>
</div>