<div class="max-w-2xl mx-auto bg-white shadow rounded-lg overflow-hidden border-2 border-purple-100">
  <% if @ingredient.photo.attached? %>
    <%= image_tag @ingredient.photo, class: "w-full h-64 object-cover" %>
  <% end %>
  
  <div class="p-6">
    <h1 class="text-3xl font-bold mb-2 text-purple-800">✨ <%= @ingredient.name %> ✨</h1>
    <p class="text-purple-500 mb-4"><%= @ingredient.category %></p>
    
    <div class="mb-6">
      <h2 class="font-bold text-purple-400 uppercase text-xs tracking-wider mb-2">Description</h2>
      <p class="text-purple-700"><%= @ingredient.description %></p>
    </div>

    <div class="flex space-x-2">
      <%= link_to 'Edit', edit_ingredient_path(@ingredient), class: "bg-purple-400 hover:bg-purple-500 text-white px-4 py-2 rounded" %>
      <%= link_to 'Back', ingredients_path, class: "text-purple-400 hover:text-purple-600 py-2" %>
    </div>
  </div>
</div>