<%= form_with(model: ingredient, class: "max-w-2xl mx-auto bg-white shadow-lg rounded-xl p-6 space-y-6 border-2 border-purple-100") do |form| %>

  <% if ingredient.errors.any? %>
    <div class="bg-pink-50 text-pink-600 px-4 py-3 rounded-lg border border-pink-200">
      <h2 class="font-semibold mb-2 flex items-center gap-2">
        <span>💫</span>
        <%= pluralize(ingredient.errors.count, "error") %> prohibited this ingredient from being saved:
      </h2>

      <ul class="list-disc ml-6 text-sm text-pink-500">
        <% ingredient.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Photo Upload Section (Original structure preserved) -->
  <div class="bg-purple-50 p-6 rounded-xl border-2 border-dashed border-purple-200">
    <%= form.label :photo, "Ingredient Photo", class: "block font-bold text-purple-700 mb-3" %>
    <div class="flex items-center justify-center w-full">
      <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-purple-200 border-dashed rounded-lg cursor-pointer bg-white hover:bg-purple-50">
        <div class="flex flex-col items-center justify-center pt-5 pb-6">
          <!-- Original SVG preserved but with purple color -->
          <svg class="w-8 h-8 mb-4 text-purple-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 16">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 13h3a3 3 0 0 0 0-6h-.025A5.56 5.56 0 0 0 16 6.5 5.5 5.5 0 0 0 5.207 5.021C5.137 5.017 5.071 5 5 5a4 4 0 0 0 0 8h2.167M10 15V6m0 0L8 8m2-2 2 2"/>
          </svg>
          <p class="mb-2 text-sm text-purple-500"><span class="font-semibold text-purple-600">Click to upload</span> or drag and drop</p>
          <p class="text-xs text-purple-400">PNG, JPG or GIF</p>
        </div>
        <%= form.file_field :photo, accept: "image/*", class: "hidden" %>
      </label>
    </div>
    <% if ingredient.photo.attached? %>
      <p class="mt-2 text-sm text-purple-500">✓ Current photo: <%= ingredient.photo.filename %></p>
    <% end %>
  </div>

  <!-- Name -->
  <div>
    <%= form.label :name, class: "block text-sm font-medium text-purple-600" %>
    <%= form.text_field :name,
      class: [
        "mt-1 block w-full rounded-md shadow-sm px-3 py-2 border-2 focus:ring-2 focus:ring-purple-300 focus:outline-none",
        ingredient.errors[:name].any? ? "border-pink-300" : "border-purple-100"
      ] %>
  </div>

  <!-- Category -->
  <div>
    <%= form.label :category, class: "block text-sm font-medium text-purple-600" %>
    <%= form.text_field :category,
      class: [
        "mt-1 block w-full rounded-md shadow-sm px-3 py-2 border-2 focus:ring-2 focus:ring-purple-300 focus:outline-none",
        ingredient.errors[:category].any? ? "border-pink-300" : "border-purple-100"
      ] %>
  </div>

  <!-- Description -->
  <div>
    <%= form.label :description, class: "block text-sm font-medium text-purple-600" %>
    <%= form.text_area :description, rows: 4,
      class: [
        "mt-1 block w-full rounded-md shadow-sm px-3 py-2 border-2 focus:ring-2 focus:ring-purple-300 focus:outline-none",
        ingredient.errors[:description].any? ? "border-pink-300" : "border-purple-100"
      ] %>
  </div>

  <!-- Notes -->
  <div>
    <%= form.label :notes, class: "block text-sm font-medium text-purple-600" %>
    <%= form.text_area :notes, rows: 4,
      class: [
        "mt-1 block w-full rounded-md shadow-sm px-3 py-2 border-2 focus:ring-2 focus:ring-purple-300 focus:outline-none",
        ingredient.errors[:notes].any? ? "border-pink-300" : "border-purple-100"
      ] %>
  </div>

  <!-- Tags Section -->
  <div class="mb-4">
    <%= form.label :tag_ids, "Benefits & Properties", class: "block font-bold text-purple-700 mb-2" %>
    <div class="grid grid-cols-2 gap-2">
      <%# collection_check_boxes helper preserved with all original comments %>
      <%# It takes 4 main arguments: 
          1. The field name (:tag_ids)
          2. The collection to loop through (Tag.all)
          3. The value to save (:id)
          4. The text to show the user (:name)
      %>
      <%= form.collection_check_boxes :tag_ids, Tag.all, :id, :name do |cb| %>
        <div class="flex items-center p-1">
          <%= cb.check_box class: "w-4 h-4 text-purple-400 border-purple-300 rounded focus:ring-purple-300" %>
          <%= cb.label class: "ml-2 text-sm text-purple-600" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Submit -->
  <div class="pt-4">
    <%= form.submit "Save Ingredient",
      class: "w-full sm:w-auto bg-purple-400 hover:bg-purple-500 text-white font-medium px-6 py-2.5 rounded-md transition duration-200 cursor-pointer shadow-sm hover:shadow-md" %>
  </div>

<% end %>