<% content_for :title, "Editing ingredient" %>

<div class="max-w-4xl mx-auto">
  <!-- Decorative header -->
  <div class="mb-8 text-center">
    <span class="inline-block text-4xl mb-2">✏️✨</span>
    <h1 class="font-bold text-4xl text-purple-700 mb-2">Editing Ingredient</h1>
    <div class="w-24 h-1 bg-gradient-to-r from-purple-300 to-pink-300 mx-auto rounded-full"></div>
  </div>

  <!-- Form container with extra cuteness -->
  <div class="bg-white rounded-xl shadow-lg p-1 border-2 border-purple-100">
    <%= render "form", ingredient: @ingredient %>
  </div>

  <!-- Action buttons - Now super cute! -->
  <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-end">
    <%= link_to @ingredient,
        class: "flex items-center justify-center gap-2 px-5 py-3 bg-purple-50 text-purple-600 rounded-xl hover:bg-purple-100 transition-all duration-200 border-2 border-purple-200 group" do %>
      <span>👁️</span>
      <span>Show this ingredient</span>
      <span class="group-hover:translate-x-1 transition-transform">→</span>
    <% end %>

    <%= link_to ingredients_path,
        class: "flex items-center justify-center gap-2 px-5 py-3 bg-white text-purple-400 rounded-xl hover:text-purple-600 hover:bg-purple-50 transition-all duration-200 border-2 border-purple-200 group" do %>
      <span>🌸</span>
      <span>Back to ingredients</span>
      <span class="group-hover:-translate-x-1 transition-transform">←</span>
    <% end %>
  </div>

  <!-- Cute little decorative element -->
  <div class="mt-8 text-center text-purple-300 text-sm">
    ✦ ✦ ✦
  </div>
</div>
