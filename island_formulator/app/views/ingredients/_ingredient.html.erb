<div class="bg-white shadow-lg rounded-xl p-6 border border-purple-100 hover:shadow-xl transition-shadow duration-300">
  <div class="mb-4">
    <span class="inline-block px-3 py-1 text-xs font-semibold tracking-wide text-purple-700 uppercase bg-purple-100 rounded-full">
      <%= ingredient.category %>
    </span>
  </div>

  <h2 class="text-xl font-bold text-purple-800 mb-2">
    <%= ingredient.name %>
  </h2>

  <p class="text-purple-600 line-clamp-3 mb-4">
    <%= ingredient.description %>
  </p>

  <p class="mt-4">
  <strong class="text-purple-700">Tags:</strong>
  <% if ingredient.tags.any? %>
    <div class="flex flex-wrap gap-2 mt-1">
      <% ingredient.tags.each do |tag| %>
        <span class="inline-block bg-purple-100 text-purple-700 text-xs font-semibold px-2.5 py-0.5 rounded-full border border-purple-300">
          <%= tag.name %>
        </span>
      <% end %>
    </div>
  <% else %>
    <span class="text-purple-300 italic">No tags selected</span>
  <% end %>
</p>

  <div class="mt-auto pt-4 border-t border-purple-100 flex justify-between items-center">
    <%= link_to "View Details", ingredient,
        class: "text-purple-500 font-medium hover:text-purple-700 transition-colors" %>

    <span class="text-purple-300 text-sm">
      #<%= ingredient.id %>
    </span>
  </div>
</div>