<% content_for :title, "Ingredients" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-purple-50 mb-5 text-purple-500 font-medium rounded-md inline-block border border-purple-200" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl text-purple-700">✨ Ingredients ✨</h1>
    <%= link_to "New ingredient", new_ingredient_path, class: "rounded-md px-3.5 py-2.5 bg-purple-400 hover:bg-purple-500 text-white block font-medium" %>
  </div>

  <div id="ingredients" class="min-w-full divide-y divide-purple-200 space-y-5">
    <% if @ingredients.any? %>
      <% @ingredients.each do |ingredient| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render ingredient %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", ingredient, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-purple-50 text-purple-600 hover:bg-purple-100 inline-block font-medium border border-purple-200" %>
            <%= link_to "Edit", edit_ingredient_path(ingredient), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-purple-50 text-purple-600 hover:bg-purple-100 inline-block font-medium border border-purple-200" %>
            <%= button_to "Destroy", ingredient, method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-pink-400 hover:bg-pink-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10 text-purple-400">No ingredients found.</p>
    <% end %>
  </div>
</div>
