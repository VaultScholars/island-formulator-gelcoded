<% content_for :title, "Batches" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-purple-50 text-purple-500 font-medium rounded-lg inline-block mb-5" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Batch History</h1>
    <%= link_to "Log New Batch", new_batch_path, class: "rounded-lg py-3 px-5 bg-purple-50 text-purple-600 hover:bg-purple-100 font-medium transition-colors" %>
  </div>

  <div id="batches" class="min-w-full mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
    <% @batches.each do |batch| %>
      <div class="bg-white shadow rounded-lg p-6 border-l-4 border-green-500">
        <div class="flex justify-between items-start">
          <div>
            <h2 class="font-bold text-xl text-gray-900"><%= batch.recipe.title %></h2>
            <p class="text-sm text-gray-500"><%= batch.made_on.strftime("%B %d, %Y") %></p>
          </div>
          <%= link_to "View Details", batch, class: "text-sm text-purple-600 hover:underline" %>
        </div>
        
        <% if batch.notes.present? %>
          <div class="mt-4 text-purple-600 italic text-sm">
            "<%= batch.notes.truncate(100) %>"
          </div>
        <% end %>
      </div>
    <% end %>
    
    <% if @batches.empty? %>
      <div class="text-center py-16 bg-white/80 backdrop-blur-sm rounded-2xl border-2 border-dashed border-purple-200">
        <span class="text-6xl block mb-4">🧪✨</span>
        <p class="text-purple-400 text-lg mb-4">No batches logged yet.</p>
        <p class="text-purple-300 mb-6">Time to start experimenting! 🌸</p>
        <%= link_to new_batch_path, class: "inline-flex items-center gap-2 bg-purple-400 hover:bg-purple-500 text-white px-6 py-3 rounded-xl font-medium transition-all duration-200 shadow-sm" do %>
          <span>✨</span>
          <span>Log Your First Batch</span>
          <span>✨</span>
      <% end %>
    </div>
  <% end %>  
</div>