<%= form_with(model: batch, class: "contents") do |form| %>
  <% if batch.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(batch.errors.count, "error") %> prohibited this batch from being saved:</h2>

      <ul class="list-disc ml-6">
        <% batch.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="inline">
    <%= form.submit class: "rounded-lg py-3 px-5 bg-purple-400 hover:bg-purple-500 text-white font-medium cursor-pointer transition-colors shadow-sm" %>
  </div>
<% end %>
