<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Island Formulator" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Island Formulator">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>



    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gradient-to-br from-purple-100 via-white to-purple-50 min-h-screen">
    <main class="container mx-auto mt-28 px-5 flex flex-col">
      <nav class="mb-8 px-6 py-4 bg-purple-50 border-b border-purple-200 shadow-sm">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <%# Left side - App name and main nav %>
    <div class="flex items-center gap-8">
      <%= link_to root_path, class: "text-xl font-bold text-purple-700 hover:text-purple-500 transition-colors" do %>
        Ingredient Knowledge Base
      <% end %>
      
      <% if authenticated? %>
        <%= link_to "Dashboard", root_path, class: "text-purple-600 hover:text-purple-400 transition-colors" %>
        <%= link_to "📋 Recipes", recipes_path, class: "text-purple-600 hover:text-purple-400 transition-colors" %>
        <%= link_to "📦 Inventory", inventory_items_path, class: "text-purple-600 hover:text-purple-400 transition-colors" %>
        <%= link_to "📝 Batches", batches_path, class: "text-purple-600 hover:text-purple-400 transition-colors" %>
        <%= link_to "🥥 Ingredients", ingredients_path, class: "text-purple-600 hover:text-purple-400 transition-colors" %>
      <% end %>
    </div>
    
    <%# Right side - Auth links %>
    <div class="flex items-center gap-4">
      <% if authenticated? %>
        <span class="text-sm text-purple-400">
          <%= Current.user.email_address %>
        </span>
        <%= button_to "Logout", session_path, method: :delete, class: "px-4 py-2 text-sm text-purple-600 hover:text-purple-700 hover:bg-purple-100 rounded-lg transition-colors" %>
      <% else %>
        <%= link_to "Sign Up ✨", new_user_path, class: "px-4 py-2 text-sm font-medium text-white bg-purple-400 hover:bg-purple-500 rounded-lg transition-colors shadow-sm" %>
        <%= link_to "Login", new_session_path, class: "px-4 py-2 text-sm font-medium text-purple-600 hover:text-purple-700 hover:bg-purple-100 rounded-lg transition-colors" %>
      <% end %>
    </div>
  </div>
</nav>
      <%= yield %>
    </main>
  </body>
</html>
